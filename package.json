{
  "name": "pact-contract-mcp",
  "version": "1.0.0",
  "description": "MCP server for automating Pact contract test creation and execution for Spring Boot, AWS Lambda, and GCP Functions",
  "author": "Sakthikannan Subramanian",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pact-contract-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js --http",
    "start:sse": "node dist/index.js --sse",
    "start:shared": "node dist/index.js --http --port 3001",
    "dev": "tsx src/index.ts",
    "dev:sse": "tsx src/index.ts --sse",
    "dev:http": "tsx src/index.ts --http",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pact",
    "contract-testing",
    "spring-boot",
    "aws-lambda",
    "gcp-functions"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
